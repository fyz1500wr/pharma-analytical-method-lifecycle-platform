{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fyz1500wr/pharma-analytical-method-lifecycle-platform/schemas/analytical_report_gap_assessment.schema.json",
  "title": "Analytical Report Gap Assessment",
  "type": "object",
  "required": ["report_title", "document_type", "overall_risk", "gaps", "reviewer_questions"],
  "properties": {
    "report_title": {"type": "string"},
    "document_type": {
      "type": "string",
      "enum": ["method_development_report", "validation_protocol", "validation_report", "method_transfer_report", "technical_proposal", "vendor_report", "other"]
    },
    "method_name": {"type": "string"},
    "method_type": {"type": "string"},
    "analytical_purpose": {"type": "array", "items": {"type": "string"}},
    "overall_risk": {"type": "string", "enum": ["critical", "high", "medium", "low", "not_assessed"]},
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "gap_description", "recommended_action"],
        "properties": {
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "clarification"]},
          "gap_description": {"type": "string"},
          "why_it_matters": {"type": "string"},
          "recommended_action": {"type": "string"},
          "evidence_level": {"type": "string"},
          "human_review_required": {"type": "boolean", "default": true}
        },
        "additionalProperties": false
      }
    },
    "reviewer_questions": {"type": "array", "items": {"type": "string"}},
    "sme_review_required": {"type": "boolean", "default": true},
    "evidence_sources": {"type": "array", "items": {"type": "string"}},
    "human_review_statement": {"type": "string"}
  },
  "additionalProperties": false
}
