{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fyz1500wr/pharma-analytical-method-lifecycle-platform/schemas/technical_context_card.schema.json",
  "title": "Technical Context Card",
  "type": "object",
  "required": ["technology_name", "principle_summary", "what_it_measures", "reviewer_focus"],
  "properties": {
    "technology_name": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "technology_status": {
      "type": "string",
      "enum": ["known_internally_mapped", "known_not_internally_mapped", "emerging_insufficient_internal_knowledge", "unclear_requires_clarification"]
    },
    "principle_summary": {"type": "string"},
    "what_it_measures": {"type": "string"},
    "signal_source": {"type": "string"},
    "suitable_for": {"type": "array", "items": {"type": "string"}},
    "not_suitable_for": {"type": "array", "items": {"type": "string"}},
    "key_controls": {"type": "array", "items": {"type": "string"}},
    "reviewer_focus": {"type": "array", "items": {"type": "string"}},
    "common_failure_modes": {"type": "array", "items": {"type": "string"}},
    "sme_review_triggers": {"type": "array", "items": {"type": "string"}},
    "evidence_sources": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string", "enum": ["high", "medium", "low", "not_assessed"]},
    "human_review_required": {"type": "boolean", "default": true}
  },
  "additionalProperties": false
}
